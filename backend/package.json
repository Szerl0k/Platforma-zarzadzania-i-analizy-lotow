{
  "name": "flight-management-backend",
  "version": "1.0.0",
  "description": "Backend for Flight Management Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "ci:migrate-and-seed": "npm run migration:run && npm run db:setup",
    "ci:migrate": "npm run typeorm migration:run -- -d src/common/database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate -d src/common/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/common/database/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/common/database/data-source.ts",
    "db:setup": "ts-node src/common/database/seeds/init-seed.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write 'src/**/*.{ts,js,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "geojson": "^0.5.0",
    "jsonwebtoken": "^9.0.3",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.20.0",
    "prettier": "^3.8.3",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.16.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
